<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
   xmlns:android="http://schemas.android.com/apk/res/android"
   android:layout_width="match_parent"
   android:layout_height="match_parent"
   android:id="@+id/main"
   android:orientation="vertical">


   <TextView
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:text="Menu Geral"
       android:layout_margin="30dp"
       android:textSize="30dp"
   />
   <Button
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:text="Tela 1"
       android:textSize="30dp"
       android:layout_margin="50dp"
       android:id="@+id/btTela1" />
   <Button
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:text="Tela 2"
       android:textSize="30dp"
       android:layout_margin="50dp"
       android:id="@+id/btTela2" />


</LinearLayout>
/* obs.: cada vez que adicionamos uma activity, o android studio alterar o arquivo AndroidManifest.xml (veja os comandos à seguir) */
<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
   xmlns:tools="http://schemas.android.com/tools">


   <application
       android:allowBackup="true"
       android:dataExtractionRules="@xml/data_extraction_rules"
       android:fullBackupContent="@xml/backup_rules"
       android:icon="@mipmap/ic_launcher"
       android:label="@string/app_name"
       android:roundIcon="@mipmap/ic_launcher_round"
       android:supportsRtl="true"
       android:theme="@style/Theme.N1_Exemplo4"
       tools:targetApi="31">
       <activity
           android:name=".Tela2"
           android:exported="false" />
       <activity
           android:name=".Tela1"
           android:exported="false" />
       <activity
           android:name=".MainActivity"
           android:exported="true">
           <intent-filter>
               <action android:name="android.intent.action.MAIN" />


               <category android:name="android.intent.category.LAUNCHER" />
           </intent-filter>
       </activity>
   </application>


</manifest>
/* Java */
package com.example.n1_exemplo4;


import androidx.appcompat.app.AppCompatActivity;


import android.content.Intent;
import android.os.Bundle;
import android.view.View;
import android.widget.Button;


public class MainActivity extends AppCompatActivity implements View.OnClickListener {
   Button btTela1, btTela2;


   @Override
   protected void onCreate(Bundle savedInstanceState) {
       super.onCreate(savedInstanceState);
       setContentView(R.layout.activity_main);


       btTela1   = findViewById(R.id.btTela1);
       btTela2   = findViewById(R.id.btTela2);
      
       btTela1.setOnClickListener(this);
       btTela2.setOnClickListener(this);
   }


   @Override
   public void onClick(View v) {
       // se a origem do click foi no botão Tela1
       if (v.getId() == R.id.btTela1){
           // comandos para chamar a tela1
           Intent tela1 = new Intent(this, Tela1.class);
           startActivity(tela1);
       }
       // se a origem do click foi no botão Tela2
       if (v.getId() == R.id.btTela2){
           // comandos para chamar a tela2
           Intent tela2 = new Intent(this, Tela2.class);
           startActivity(tela2);
       }
   }
}
